APP_NAME="Alpha eLibrary"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Asia/Phnom_Penh

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Database (Central) ───────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=alpha_elibrary_central
DB_USERNAME=postgres
DB_PASSWORD=

# ─── Tenancy ──────────────────────────────────────────────────────────────────
TENANCY_DATABASE_PREFIX=alpha_elibrary_tenant_
TENANCY_SUBDOMAIN_PATTERN="{tenant}.localhost"

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Cache / Session / Queue ──────────────────────────────────────────────────
BROADCAST_CONNECTION=reverb
CACHE_STORE=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ─── Storage ──────────────────────────────────────────────────────────────────
# Default: Use Cloudflare R2 for all tenants
FILESYSTEM_DISK=default_r2

# Cloudflare R2 (Default System-wide Storage)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ACCOUNT_ID=
R2_BUCKET=alpha-elibrary-files
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_PUBLIC_URL=

# Legacy AWS S3 (for backward compatibility)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=alpha-elibrary-files
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── Mail (Brevo SMTP) ────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@alphaelibrary.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Laravel AI SDK ───────────────────────────────────────────────────────────
AI_DEFAULT_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─── Laravel Reverb (WebSockets) ──────────────────────────────────────────────
REVERB_APP_ID=alpha-elibrary
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ─── Scout (Search) ───────────────────────────────────────────────────────────
SCOUT_DRIVER=database

# ─── Open Library API ─────────────────────────────────────────────────────────
OPEN_LIBRARY_API=https://openlibrary.org/api/books

# ─── Google Gemini API (AI-Powered Cataloging) ───────────────────────────────
GEMINI_API_KEY=
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-1.5-flash

# ─── Vite ─────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
